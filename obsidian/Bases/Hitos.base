filters:
  and:
    - file.hasTag("sistema")
    - file.ext == "md"
properties:
  hito:
    displayName: Hito
  system_status:
    displayName: Estado
  status:
    displayName: Nota
views:
  - type: table
    name: Sistemas por hito
    groupBy:
      property: hito
      direction: ASC
    order:
      - file.name
      - hito
      - system_status
      - status
